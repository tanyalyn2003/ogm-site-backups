RewriteEngine On

# Redirect /index.html to the canonical homepage URL.
RewriteRule ^index\.html$ https://oliveglassandmarble.com/ [R=301,L]

# Redirect legacy paths from the previous site structure to the current pages.
RewriteRule ^stone(?:/index\.html)?/?$ https://oliveglassandmarble.com/countertops.html [NC,R=301,L]
RewriteRule ^contact-us(?:/index\.html)?/?$ https://oliveglassandmarble.com/contact.html [NC,R=301,L]
RewriteRule ^galleries(?:/.*)?$ https://oliveglassandmarble.com/gallery.html [NC,R=301,L]
RewriteRule ^wp-content/uploads/.*/mirrored-.*$ https://oliveglassandmarble.com/glass.html [NC,R=301,L]
RewriteRule ^wp-content/uploads/.*/floatin.*$ https://oliveglassandmarble.com/gallery.html [NC,R=301,L]
RewriteRule ^wp-content/uploads/.*$ https://oliveglassandmarble.com/gallery.html [NC,R=301,L]

# Redirect old feed-style URLs from the previous site structure.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([A-Za-z0-9-]+)/feed(?:/index\.html)?$ https://oliveglassandmarble.com/$1.html [NC,R=301,L]
RewriteRule ^welcome-to-olive-glass-marble/feed(?:/index\.html)?$ https://oliveglassandmarble.com/ [NC,R=301,L]

# Redirect old folder-style URLs such as /about/, /about/index.html, or /commercial/
# to their current flat .html pages when a matching page exists.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([A-Za-z0-9-]+)(?:/index\.html|/?)$ https://oliveglassandmarble.com/$1.html [NC,R=301,L]

# Force the canonical host and HTTPS:
# - http://oliveglassandmarble.com -> https://oliveglassandmarble.com
# - http://www.oliveglassandmarble.com -> https://oliveglassandmarble.com
# - https://www.oliveglassandmarble.com -> https://oliveglassandmarble.com
# - https://mail.oliveglassandmarble.com -> https://oliveglassandmarble.com
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^(?:www|mail)\.oliveglassandmarble\.com$ [NC]
RewriteRule ^ https://oliveglassandmarble.com%{REQUEST_URI} [R=301,L]

# Send UTF-8 in the HTTP response headers.
AddDefaultCharset UTF-8

# Keep build helpers, editor files, and quota files out of the public web.
RedirectMatch 403 (?i)^/(?:scripts|partials|logs|bin)(?:/|$)
RedirectMatch 403 (?i)^/(?:ftpquota|\.ftpquota|htaccess-upload\.txt|OGM_Website\.code-workspace)$
<Files "products still needs to complete.html">
  Require all denied
</Files>

# Basic hardening headers that are safe for this static site + PHP contact endpoint.
<IfModule mod_headers.c>
  Header always set X-Robots-Tag "index, follow"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header merge Vary "Accept-Encoding"
  <FilesMatch "\.(?:css|js|mjs|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:html?|xml|txt)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# Compress text-based assets when Apache modules are available.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Cache-bustable assets already use versioned URLs, so keep them warm in browsers.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/plain "access plus 5 minutes"
  ExpiresByType text/xml "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
</IfModule>
